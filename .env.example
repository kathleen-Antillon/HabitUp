# PostgreSQL (Neon, Vercel Postgres, Supabase, etc.)
DATABASE_URL="postgresql://USER:PASSWORD@HOST/DATABASE?sslmode=require"

SESSION_SECRET="change-me-to-a-long-random-secret"
NEXT_PUBLIC_APP_URL="http://localhost:3000"

# Email (Resend) — https://resend.com
# Sin RESEND_API_KEY, el link de recuperación se imprime en la consola del servidor (dev).
RESEND_API_KEY=""
EMAIL_FROM="HabitUp <onboarding@resend.dev>"

# Cron (Vercel) — recordatorios de objetivos diarios
CRON_SECRET=""
# daily = 1 cron/día (Hobby). hourly = filtra por hora local (Pro + cron cada hora)
GOAL_REMINDER_MODE="daily"
# Solo con GOAL_REMINDER_MODE=hourly — hora local del usuario (0-23, default 20)
GOAL_REMINDER_HOUR="20"

# Google OAuth — https://console.cloud.google.com/apis/credentials
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""
NEXT_PUBLIC_GOOGLE_AUTH_ENABLED="false"
